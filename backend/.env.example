# Copy to .env (see README + RAILWAY_DEPLOY.md)
# Local Postgres via Docker: docker compose up -d (repo root)
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/teamtasks?schema=public"
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN="7d"
PORT=4000
CLIENT_ORIGIN="http://localhost:5173"
NODE_ENV="development"

# Optional seed overrides (npm run db:seed)
# SEED_ADMIN_EMAIL=
# SEED_ADMIN_PASSWORD=
# SEED_MEMBER_EMAIL=
# SEED_MEMBER_PASSWORD=
